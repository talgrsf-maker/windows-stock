{
  "name": "windows-stock",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "desktop": "npm run build && electron .",
    "build:exe": "npm run build && electron-builder --win portable"
  },
  "dependencies": { "@supabase/supabase-js": "^2.49.1", "@vitejs/plugin-react": "^4.3.4", "vite": "^6.1.0", "react": "^19.0.0", "react-dom": "^19.0.0" },
  "devDependencies": { "typescript": "^5.7.3", "vitest": "^3.0.7", "@types/react": "^19.0.8", "@types/react-dom": "^19.0.3" },
  "build": {
    "appId": "il.co.windowsstock.app",
    "productName": "Windows Stock",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*", "package.json"],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "artifactName": "Windows-Stock-${version}.exe"
    }
  }
}
